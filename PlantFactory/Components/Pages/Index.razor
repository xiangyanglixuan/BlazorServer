@page "/"

<PageTitle>植物工厂监控系统 - 系统概览</PageTitle>

<div class="page-content">
    <div class="overview-header">
        <h1>植物工厂监控系统</h1>
        @* <p class="lead">智能农业监控与管理平台</p> *@
    </div>

    <div class="dashboard-cards">
        <div class="dashboard-card">
            <div class="card-icon bg-primary">
                <i class="fas fa-th-large"></i>
            </div>
            <div class="card-content">
                <h3>库位监测</h3>
                <p>实时监控植物生长状态和库位利用率</p>
                <a href="/location-monitoring" class="card-link">查看详情 <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-icon bg-success">
                <i class="fas fa-cloud-sun"></i>
            </div>
            <div class="card-content">
                <h3>环境监测</h3>
                <p>监控温度、湿度、CO₂、光照和营养液参数</p>
                <a href="/air-monitoring" class="card-link">查看详情 <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-icon bg-info">
                <i class="fas fa-leaf"></i>
            </div>
            <div class="card-content">
                <h3>植物管理</h3>
                <p>管理植物类别和生长配方</p>
                <a href="/plant-category" class="card-link">查看详情 <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="dashboard-card">
            <div class="card-icon bg-warning">
                <i class="fas fa-warehouse"></i>
            </div>
            <div class="card-content">
                <h3>出入库管理</h3>
                <p>管理植物入库和出库流程</p>
                <a href="/inbound" class="card-link">查看详情 <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>

    <div class="system-status-overview">
        <h2>系统状态概览</h2>
        <div class="status-grid">
            <div class="status-item status-normal">
                <i class="fas fa-check-circle"></i>
                <span>库位监测</span>
                <span class="status-text">正常</span>
            </div>
            <div class="status-item status-normal">
                <i class="fas fa-check-circle"></i>
                <span>环境监测</span>
                <span class="status-text">正常</span>
            </div>
            <div class="status-item status-warning">
                <i class="fas fa-exclamation-triangle"></i>
                <span>设备状态</span>
                <span class="status-text">2个报警</span>
            </div>
            <div class="status-item status-normal">
                <i class="fas fa-check-circle"></i>
                <span>数据统计</span>
                <span class="status-text">正常</span>
            </div>
        </div>
    </div>
</div>

@code {
