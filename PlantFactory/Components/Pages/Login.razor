@page "/login"
@inject NavigationManager Navigation
@inject IJSRuntime JS
@layout EmptyLayout

<PageTitle>登录 - 植物工厂智能监控系统</PageTitle>

<style>
    /* 登录页面样式 */
    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        position: relative;
        overflow: hidden;
        padding: 20px;
    }

    .login-card {
        width: 100%;
        max-width: 1000px;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        display: flex;
        overflow: hidden;
        position: relative;
        z-index: 10;
        backdrop-filter: blur(10px);
        animation: cardAppear 0.6s ease-out;
    }

    /* 左侧装饰区域 */
    .login-decoration {
        flex: 1;
        background: linear-gradient(135deg, #43cea2 0%, #185a9d 100%);
        padding: 40px;
        display: flex !important;
        align-items: center;
        justify-content: center;
        color: white;
        position: relative;
        overflow: hidden;
    }

        .login-decoration::before {
            content: '';
            position: absolute;
            width: 200%;
            height: 200%;
            background: rgba(255, 255, 255, 0.1);
            transform: rotate(45deg);
            top: -50%;
            left: -50%;
            animation: shimmer 15s infinite linear;
        }


    .decoration-content {
        text-align: center;
        position: relative;
        z-index: 1;
    }

    .decoration-icon {
        font-size: 4rem;
        margin-bottom: 20px;
        animation: float 3s ease-in-out infinite;
    }

    .decoration-content h2 {
        font-size: 2rem;
        margin-bottom: 10px;
        font-weight: 600;
    }

    .decoration-content p {
        font-size: 1.1rem;
        opacity: 0.9;
        margin-bottom: 40px;
    }

   /*  .decoration-features {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-top: 30px;
    } */

   /*  .feature-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 10px 20px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 50px;
        backdrop-filter: blur(5px);
        animation: slideIn 0.5s ease-out forwards;
        opacity: 0;
        transform: translateX(-20px);
    }

        .feature-item:nth-child(1) {
            animation-delay: 0.2s;
        }

        .feature-item:nth-child(2) {
            animation-delay: 0.4s;
        }

        .feature-item:nth-child(3) {
            animation-delay: 0.6s;
        }



        .feature-item i {
            font-size: 1.2rem;
            width: 24px;
        }

        .feature-item span {
            font-size: 1rem;
            font-weight: 500;
        } */

    /* 右侧登录表单 */
    .login-form-container {
        flex: 1;
        padding: 60px 40px;
        background: white;
    }

    .login-form-content {
        max-width: 360px;
        margin: 0 auto;
    }

    .login-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .login-header h2 {
            font-size: 2rem;
            color: #333;
            margin-bottom: 10px;
            font-weight: 600;
        }

        .login-header p {
            color: #666;
            font-size: 1rem;
        }

    /* 表单组 */
    .form-group {
        margin-bottom: 25px;
        position: relative;
    }

        .form-group label {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
            color: #555;
            font-weight: 500;
            font-size: 0.9rem;
        }

            .form-group label i {
                color: #667eea;
                width: 16px;
            }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e1e1e1;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #f8f9fa;
    }

        .form-control:focus {
            outline: none;
            border-color: #667eea;
            background: white;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
        }

    .form-group.has-error .form-control {
        border-color: #f44336;
        background: #fff8f8;
    }

    .error-message {
        display: flex;
        align-items: center;
        gap: 5px;
        color: #f44336;
        font-size: 0.85rem;
        margin-top: 5px;
        animation: shake 0.3s ease-in-out;
    }


    /* 密码输入框 */
    .password-input-wrapper {
        position: relative;
    }

    .password-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #999;
        cursor: pointer;
        padding: 5px;
        transition: color 0.3s ease;
    }

        .password-toggle:hover {
            color: #667eea;
        }

    /* 表单选项 */
    .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .checkbox-container {
        display: flex;
        align-items: center;
        position: relative;
        padding-left: 28px;
        cursor: pointer;
        user-select: none;
        color: #666;
        font-size: 0.9rem;
    }

        .checkbox-container input {
            position: absolute;
            opacity: 0;
            cursor: pointer;
            height: 0;
            width: 0;
        }

    .checkmark {
        position: absolute;
        top: 0;
        left: 0;
        height: 18px;
        width: 18px;
        background-color: #f8f9fa;
        border: 2px solid #e1e1e1;
        border-radius: 4px;
        transition: all 0.3s ease;
    }

    .checkbox-container:hover input ~ .checkmark {
        border-color: #667eea;
    }

    .checkbox-container input:checked ~ .checkmark {
        background-color: #667eea;
        border-color: #667eea;
    }

    .checkmark:after {
        content: "";
        position: absolute;
        display: none;
    }

    .checkbox-container input:checked ~ .checkmark:after {
        display: block;
    }

    .checkbox-container .checkmark:after {
        left: 5px;
        top: 2px;
        width: 4px;
        height: 8px;
        border: solid white;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
    }

    .checkbox-text {
        margin-left: 5px;
    }

    .forgot-password {
        color: #667eea;
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.3s ease;
    }

        .forgot-password:hover {
            color: #764ba2;
            text-decoration: underline;
        }

    /* 登录按钮 */
    .login-button {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 12px;
        color: white;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .login-button::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .login-button:hover:not(:disabled)::before {
            width: 300px;
            height: 300px;
        }

        .login-button:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.4);
        }

        .login-button:active:not(:disabled) {
            transform: translateY(0);
        }

        .login-button:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

    /* 其他登录方式 */
    .other-login {
        margin-top: 30px;
    }

    .divider {
        text-align: center;
        position: relative;
        margin: 20px 0;
    }

        .divider::before,
        .divider::after {
            content: '';
            position: absolute;
            top: 50%;
            width: calc(50% - 70px);
            height: 1px;
            background: #e1e1e1;
        }

        .divider::before {
            left: 0;
        }

        .divider::after {
            right: 0;
        }

        .divider span {
            background: white;
            padding: 0 10px;
            color: #999;
            font-size: 0.9rem;
        }

    .social-login {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin: 20px 0;
    }

    .social-btn {
        width: 45px;
        height: 45px;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 1.2rem;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .social-btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .social-btn:hover::before {
            width: 100px;
            height: 100px;
        }

        .social-btn.wechat {
            background: #07C160;
        }

        .social-btn.qq {
            background: #12B7F5;
        }

        .social-btn.github {
            background: #333;
        }

        .social-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

    /* 注册提示 */
    .register-prompt {
        text-align: center;
        color: #666;
        font-size: 0.9rem;
    }

        .register-prompt a {
            color: #667eea;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s ease;
        }

            .register-prompt a:hover {
                color: #764ba2;
                text-decoration: underline;
            }

    /* 浮动形状 */
    .floating-shapes {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        z-index: 1;
    }

    .shape {
        position: absolute;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        animation: floatShape 20s infinite linear;
    }

    .shape1 {
        width: 200px;
        height: 200px;
        top: -100px;
        right: -100px;
        animation-delay: 0s;
    }

    .shape2 {
        width: 300px;
        height: 300px;
        bottom: -150px;
        left: -150px;
        animation-delay: 5s;
    }

    .shape3 {
        width: 150px;
        height: 150px;
        top: 50%;
        left: 10%;
        animation-delay: 10s;
    }

    .shape4 {
        width: 100px;
        height: 100px;
        bottom: 20%;
        right: 15%;
        animation-delay: 15s;
    }

    .loading-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .loading-spinner {
        width: 50px;
        height: 50px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 1s ease-in-out infinite;
        margin-bottom: 20px;
    }

    .loading-container p {
        font-size: 1.1rem;
        opacity: 0.9;
    }
</style>

<div class="login-container">
    <div class="login-card">
        <!-- 左侧装饰区域 -->
        <div class="login-decoration">
            <div class="decoration-content">
                <i class="fas fa-seedling decoration-icon"></i>
                <h2>植物工厂</h2>
                <p>智能监控系统</p>
                @* <div class="decoration-features">
                    <div class="feature-item">
                        <i class="fas fa-temperature-high"></i>
                        <span>环境监控</span>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-droplet"></i>
                        <span>智能灌溉</span>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-leaf"></i>
                        <span>生长分析</span>
                    </div>
                </div> *@
            </div>
        </div>

        <!-- 右侧登录表单 -->
        <div class="login-form-container">
            <div class="login-form-content">
                <div class="login-header">
                    <h2>欢迎回来</h2>
                    <p>请登录您的账号</p>
                </div>

                <div class="login-form">
                    <!-- 用户名输入框 -->
                    <div class="form-group @(_usernameError ? "has-error" : "")">
                        <label for="username">
                            <i class="fas fa-user"></i>
                            用户名
                        </label>
                        <input type="text"
                               id="username"
                               class="form-control"
                               placeholder="请输入用户名"
                               @bind="username"
                               @bind:event="oninput"
                               @onkeypress="HandleKeyPress" />
                        @if (_usernameError)
                        {
                            <span class="error-message">
                                <i class="fas fa-exclamation-circle"></i>
                                @_usernameErrorMessage
                            </span>
                        }
                    </div>

                    <!-- 密码输入框 -->
                    <div class="form-group @(_passwordError ? "has-error" : "")">
                        <label for="password">
                            <i class="fas fa-lock"></i>
                            密码
                        </label>
                        <div class="password-input-wrapper">
                            <input type="@(_showPassword ? "text" : "password")"
                                   id="password"
                                   class="form-control"
                                   placeholder="请输入密码"
                                   @bind="password"
                                   @bind:event="oninput"
                                   @onkeypress="HandleKeyPress" />
                            <button type="button"
                                    class="password-toggle"
                                    @onclick="TogglePasswordVisibility">
                                <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>

                        @if (_passwordError)
                        {
                            <span class="error-message">
                                <i class="fas fa-exclamation-circle"></i>
                                @_passwordErrorMessage
                            </span>
                        }
                    </div>

                    <!-- 记住密码和忘记密码 -->
                    <div class="form-options">
                        <label class="checkbox-container">
                            <input type="checkbox" @bind="rememberMe" />
                            <span class="checkmark"></span>
                            <span class="checkbox-text">记住密码</span>
                        </label>
                        <a href="#" class="forgot-password">忘记密码？</a>
                    </div>

                    <!-- 登录按钮 -->
                    <button class="login-button"
                            @onclick="HandleLogin"
                            disabled="@_isLoggingIn">
                        @if (_isLoggingIn)
                        {
                            <i class="fas fa-spinner fa-spin"></i>
                            <span>登录中...</span>
                        }
                        else
                        {
                            <span>登录</span>
                        }
                    </button>

                   @*  <!-- 其他登录方式 -->
                    <div class="other-login">
                        <div class="divider">
                            <span>其他登录方式</span>
                        </div>
                        <div class="social-login">
                            <button class="social-btn wechat">
                                <i class="fab fa-weixin"></i>
                            </button>
                            <button class="social-btn qq">
                                <i class="fab fa-qq"></i>
                            </button>
                            <button class="social-btn github">
                                <i class="fab fa-github"></i>
                            </button>
                        </div>
                    </div>

                    <!-- 注册提示 -->
                    <div class="register-prompt">
                        还没有账号？<a href="#">立即注册</a>
                    </div> *@
                </div>
            </div>
        </div>
    </div>

    <!-- 动态背景效果 -->
    <div class="floating-shapes">
        <div class="shape shape1"></div>
        <div class="shape shape2"></div>
        <div class="shape shape3"></div>
        <div class="shape shape4"></div>
    </div>
</div>

@code {
    private string username;
    private string password;
    private bool rememberMe;
    private bool _showPassword;
    private bool _isLoggingIn;
    private bool _isChecking = true; // 添加检查状态

    // 错误状态
    private bool _usernameError;
    private bool _passwordError;
    private string _usernameErrorMessage;
    private string _passwordErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 检查是否已经登录
            var isLoggedIn = await CheckLoginStatus();
            if (isLoggedIn)
            {
                // 如果已登录，跳转到首页
                Navigation.NavigateTo("/", false); // 使用 false 避免强制刷新
            }
        }
        finally
        {
            _isChecking = false;
            StateHasChanged();
        }
    }

    private async Task<bool> CheckLoginStatus()
    {
        try
        {
            // 检查 localStorage
            var localLogin = await JS.InvokeAsync<string>("localStorage.getItem", "isLoggedIn");
            if (localLogin == "true")
                return true;

            // 检查 sessionStorage
            var sessionLogin = await JS.InvokeAsync<string>("sessionStorage.getItem", "isLoggedIn");
            return sessionLogin == "true";
        }
        catch
        {
            return false;
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private async Task HandleLogin()
    {
        // 重置错误状态
        _usernameError = false;
        _passwordError = false;

        // 验证输入
        bool isValid = true;

        if (string.IsNullOrWhiteSpace(username))
        {
            _usernameError = true;
            _usernameErrorMessage = "请输入用户名";
            isValid = false;
        }

        if (string.IsNullOrWhiteSpace(password))
        {
            _passwordError = true;
            _passwordErrorMessage = "请输入密码";
            isValid = false;
        }

        if (!isValid)
        {
            return;
        }

        _isLoggingIn = true;
        StateHasChanged();

        try
        {
            // 模拟登录验证
            await Task.Delay(1500);

            // 简单的验证示例
            if (username == "admin" && password == "123456")
            {
                // 登录成功，保存登录状态
                await SaveLoginState();

                // 跳转到首页，使用 false 避免强制刷新
                Navigation.NavigateTo("/", false);
            }
            else if (username == "manager" && password == "123456")
            {
                await SaveLoginState();

                Navigation.NavigateTo("/", false);
            }
            else if (username == "operator" && password == "123456")
            {
                await SaveLoginState();
                Navigation.NavigateTo("/", false);
            }
            else
            {
                // 登录失败
                _passwordError = true;
                _passwordErrorMessage = "用户名或密码错误";
                _isLoggingIn = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _passwordError = true;
            _passwordErrorMessage = $"登录失败：{ex.Message}";
            _isLoggingIn = false;
            StateHasChanged();
        }
    }

    private async Task SaveLoginState()
    {
        try
        {
            // 根据用户名确定角色和其他信息
            string userRole = DetermineUserRole(username);
            string userEmail = DetermineUserEmail(username);
            string userPhone = DetermineUserPhone(username);
            string lastLoginIp = await GetClientIp();
        
            // 获取当前登录时间
            string currentTime = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
        
            var storage = rememberMe ? "localStorage" : "sessionStorage";
        
            // 保存所有用户信息
            await JS.InvokeVoidAsync($"{storage}.setItem", "isLoggedIn", "true");
            await JS.InvokeVoidAsync($"{storage}.setItem", "username", username);
            await JS.InvokeVoidAsync($"{storage}.setItem", "userRole", userRole);
            await JS.InvokeVoidAsync($"{storage}.setItem", "loginTime", currentTime);
            await JS.InvokeVoidAsync($"{storage}.setItem", "userEmail", userEmail);
            await JS.InvokeVoidAsync($"{storage}.setItem", "userPhone", userPhone);
            await JS.InvokeVoidAsync($"{storage}.setItem", "lastLoginIp", lastLoginIp);
        
            // 清除另一种存储方式
            string otherStorage = rememberMe ? "sessionStorage" : "localStorage";
            await JS.InvokeVoidAsync($"{otherStorage}.removeItem", "isLoggedIn");
            await JS.InvokeVoidAsync($"{otherStorage}.removeItem", "username");
            await JS.InvokeVoidAsync($"{otherStorage}.removeItem", "userRole");
            await JS.InvokeVoidAsync($"{otherStorage}.removeItem", "loginTime");
            await JS.InvokeVoidAsync($"{otherStorage}.removeItem", "userEmail");
            await JS.InvokeVoidAsync($"{otherStorage}.removeItem", "userPhone");
            await JS.InvokeVoidAsync($"{otherStorage}.removeItem", "lastLoginIp");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"保存登录状态失败：{ex.Message}");
        }
    }

    // 根据用户名确定角色
    private string DetermineUserRole(string username)
    {
        return username.ToLower() switch
        {
            "admin" => "超级管理员",
            "administrator" => "超级管理员",
            "manager" => "系统管理员",
            "operator" => "操作员",
            "user" => "普通用户",
            "guest" => "访客",
            _ => "普通用户"
        };
    }

    // 根据用户名确定邮箱
    private string DetermineUserEmail(string username)
    {
        return username.ToLower() switch
        {
            "admin" => "admin@plantfactory.com",
            "administrator" => "admin@plantfactory.com",
            "manager" => "manager@plantfactory.com",
            "operator" => "operator@plantfactory.com",
            "user" => "user@plantfactory.com",
            "guest" => "guest@plantfactory.com",
            _ => $"{username.ToLower()}@plantfactory.com"
        };
    }

    // 根据用户名确定电话
    private string DetermineUserPhone(string username)
    {
        return username.ToLower() switch
        {
            "admin" => "138-8888-8888",
            "administrator" => "138-8888-8888",
            "manager" => "139-9999-9999",
            "operator" => "137-7777-7777",
            "user" => "136-6666-6666",
            "guest" => "135-5555-5555",
            _ => "136-6666-6666"
        };
    }

    // 获取客户端IP（示例方法）
    private async Task<string> GetClientIp()
    {
        try
        {
            // 这里可以通过JS获取客户端的IP
            // 简单起见，返回模拟数据
            return "192.168.1." + new Random().Next(1, 255);
        }
        catch
        {
            return "192.168.1.100";
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await HandleLogin();
        }
    }

    // 添加一个方法来判断是否显示登录表单
    private bool ShowLoginForm()
    {
        return !_isChecking && !_isLoggingIn;
    }
}