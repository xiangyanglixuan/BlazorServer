@code {
	private List<InoutBounds> bounds;
	private InoutBounds currentBound = new InoutBounds();
	private bool showDialog = false;

	protected override async Task OnInitializedAsync()
	{
		await LoadBounds();
	}

	private async Task LoadBounds()
	{
		bounds = await InBoundService.GetAllBoundAsync();
	}

	private void ShowAddDialog()
	{
		currentBound = new InoutBounds();
		showDialog = true;
	}

	private void EditPlant(InoutBounds bound)
	{
		currentBound = new InoutBounds
			{
				Id = bound.Id,
				PlantName = bound.PlantName,
				NumberofPiles = bound.NumberofPiles,
				NumofColumns = bound.NumofColumns,
				InboundTime = bound.InboundTime
			};
		showDialog = true;
	}


	private async void SaveBound()
	{
		if (currentBound.Id == 0)
		{
			// 添加新入库
			await InBoundService.AddBoundAsync(currentBound);
		}
		else
		{
			// 更新现有入库
			await InBoundService.UpdateBoundAsync(currentBound);
		}
		showDialog = false;
		await LoadBounds();
	}

	private void CloseDialog()
	{
		showDialog = false;
	}
}
 *@