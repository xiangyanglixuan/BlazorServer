@* Components/Layout/NavMenu.razor *@
@using Microsoft.AspNetCore.Components.Routing
@using PlantFactory.Components.Services
@inject LanguageService Lang
@implements IDisposable

<div class="nav-container">
    @* 带有二级菜单的项 *@
    <NavMenuItem Title="@Lang.T("MenuLocationMonitor")"
                 Icon="fas fa-th-large"
                 IsOpen="@IsSectionOpen("location")"
                 OnToggle="@(() => ToggleSection("location"))"
                 Collapsed="@SidebarCollapsed">
        <NavLink href="/location-monitoring" class="sub-nav">
            <i class="fas fa-circle-notch"></i>
            <span>@Lang.T("MenuLocationStatus")</span>
        </NavLink>
        <NavLink href="/location-analysis" class="sub-nav">
            <i class="fas fa-chart-bar"></i>
            <span>@Lang.T("MenuLocationAnalysis")</span>
        </NavLink>
    </NavMenuItem>

    <NavMenuItem Title="@Lang.T("MenuEnvMonitor")"
                 Icon="fas fa-cloud-sun"
                 IsOpen="@IsSectionOpen("environment")"
                 OnToggle="@(() => ToggleSection("environment"))"
                 Collapsed="@SidebarCollapsed">
        <NavLink href="/air-monitoring" class="sub-nav">
            <i class="fas fa-wind"></i>
            <span>@Lang.T("MenuAirMonitor")</span>
        </NavLink>
        <NavLink href="/nutrient-monitoring" class="sub-nav">
            <i class="fas fa-tint"></i>
            <span>@Lang.T("MenuNutrientMonitor")</span>
        </NavLink>
    </NavMenuItem>

    @* 普通菜单项 *@
    <NavLink href="/plant-category" class="nav-link" data-title="@Lang.T("MenuPlantCategory")">
        <i class="fas fa-leaf"></i>
        <span>@Lang.T("MenuPlantCategory")</span>
    </NavLink>

    <NavLink href="/growth-formula" class="nav-link" data-title="@Lang.T("MenuGrowthFormula")">
        <i class="fas fa-prescription-bottle"></i>
        <span>@Lang.T("MenuGrowthFormula")</span>
    </NavLink>

    @* 带有二级菜单的项 *@
    <NavMenuItem Title="@Lang.T("MenuWarehouse")"
                 Icon="fas fa-warehouse"
                 IsOpen="@IsSectionOpen("warehouse")"
                 OnToggle="@(() => ToggleSection("warehouse"))"
                 Collapsed="@SidebarCollapsed">
        <NavLink href="/inbound" class="sub-nav">
            <i class="fas fa-sign-in-alt"></i>
            <span>@Lang.T("MenuInbound")</span>
        </NavLink>
        <NavLink href="/outbound" class="sub-nav">
            <i class="fas fa-sign-out-alt"></i>
            <span>@Lang.T("MenuOutbound")</span>
        </NavLink>
    </NavMenuItem>

    <NavMenuItem Title="@Lang.T("MenuDevice")"
                 Icon="fas fa-cogs"
                 IsOpen="@IsSectionOpen("device")"
                 OnToggle="@(() => ToggleSection("device"))"
                 Collapsed="@SidebarCollapsed">
        <NavLink href="/alarm-management" class="sub-nav">
            <i class="fas fa-exclamation-triangle"></i>
            <span>@Lang.T("MenuAlarm")</span>
        </NavLink>
        <NavLink href="/device-monitoring" class="sub-nav">
            <i class="fas fa-desktop"></i>
            <span>@Lang.T("MenuDeviceStatus")</span>
        </NavLink>
    </NavMenuItem>

    @* 普通菜单项 *@
    <NavLink href="/data-statistics" class="nav-link" data-title="@Lang.T("MenuDataStats")">
        <i class="fas fa-chart-line"></i>
        <span>@Lang.T("MenuDataStats")</span>
    </NavLink>
</div>

@code {
    [CascadingParameter]
    private bool SidebarCollapsed { get; set; }

    private HashSet<string> _openSections = new HashSet<string>();

    protected override void OnInitialized()
    {
        Lang.OnLanguageChanged += StateHasChanged;
    }

    private bool IsSectionOpen(string sectionId)
    {
        return _openSections.Contains(sectionId);
    }

    private void ToggleSection(string sectionId)
    {
        if (SidebarCollapsed) return;

        if (_openSections.Contains(sectionId))
        {
            _openSections.Remove(sectionId);
        }
        else
        {
            _openSections.Add(sectionId);
        }
        StateHasChanged();
    }

    public void Dispose()
    {
        Lang.OnLanguageChanged -= StateHasChanged;
    }
}