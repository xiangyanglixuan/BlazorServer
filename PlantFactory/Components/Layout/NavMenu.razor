@* Components/Layout/NavMenu.razor *@
@using Microsoft.AspNetCore.Components.Routing

<div class="nav-container">
    @* 带有二级菜单的项 *@
    <NavMenuItem Title="库位监测"
                 Icon="fas fa-th-large"
                 IsOpen="@IsSectionOpen("location")"
                 OnToggle="@(() => ToggleSection("location"))"
                 Collapsed="@SidebarCollapsed">
        <NavLink href="/location-monitoring" class="sub-nav">
            <i class="fas fa-circle-notch"></i>
            <span>库位状态监测</span>
        </NavLink>
        <NavLink href="/location-analysis" class="sub-nav">
            <i class="fas fa-chart-bar"></i>
            <span>库位统计分析</span>
        </NavLink>
    </NavMenuItem>

    <NavMenuItem Title="环境监测"
                 Icon="fas fa-cloud-sun"
                 IsOpen="@IsSectionOpen("environment")"
                 OnToggle="@(() => ToggleSection("environment"))"
                 Collapsed="@SidebarCollapsed">
        <NavLink href="/air-monitoring" class="sub-nav">
            <i class="fas fa-wind"></i>
            <span>空气参数监测</span>
        </NavLink>
        <NavLink href="/nutrient-monitoring" class="sub-nav">
            <i class="fas fa-tint"></i>
            <span>营养液监测</span>
        </NavLink>
    </NavMenuItem>

    @* 普通菜单项 *@
    <NavLink href="/plant-category" class="nav-link" data-title="植物类别管理">
        <i class="fas fa-leaf"></i>
        <span>植物类别管理</span>
    </NavLink>

    <NavLink href="/growth-formula" class="nav-link" data-title="植物生长配方管理">
        <i class="fas fa-prescription-bottle"></i>
        <span>植物生长配方管理</span>
    </NavLink>

    @* 带有二级菜单的项 *@
    <NavMenuItem Title="出入库管理"
                 Icon="fas fa-warehouse"
                 IsOpen="@IsSectionOpen("warehouse")"
                 OnToggle="@(() => ToggleSection("warehouse"))"
                 Collapsed="@SidebarCollapsed">
        <NavLink href="/inbound" class="sub-nav">
            <i class="fas fa-sign-in-alt"></i>
            <span>入库管理</span>
        </NavLink>
        <NavLink href="/outbound" class="sub-nav">
            <i class="fas fa-sign-out-alt"></i>
            <span>出库管理</span>
        </NavLink>
    </NavMenuItem>

    <NavMenuItem Title="设备管理"
                 Icon="fas fa-cogs"
                 IsOpen="@IsSectionOpen("device")"
                 OnToggle="@(() => ToggleSection("device"))"
                 Collapsed="@SidebarCollapsed">
        <NavLink href="/alarm-management" class="sub-nav">
            <i class="fas fa-exclamation-triangle"></i>
            <span>设备报警管理</span>
        </NavLink>
        <NavLink href="/device-monitoring" class="sub-nav">
            <i class="fas fa-desktop"></i>
            <span>设备状态监控(SCADA)</span>
        </NavLink>
    </NavMenuItem>

    @* 普通菜单项 *@
    <NavLink href="/data-statistics" class="nav-link" data-title="数据统计">
        <i class="fas fa-chart-line"></i>
        <span>数据统计</span>
    </NavLink>
</div>

@code {
    [CascadingParameter]
    private bool SidebarCollapsed { get; set; }

    private HashSet<string> _openSections = new HashSet<string>();

    protected override void OnInitialized()
    {
        // 初始化时可以默认展开某个菜单
        // _openSections.Add("location");
    }

    private bool IsSectionOpen(string sectionId)
    {
        return _openSections.Contains(sectionId);
    }

    private void ToggleSection(string sectionId)
    {
        // 如果侧边栏收起，不处理点击事件（通过悬停显示子菜单）
        if (SidebarCollapsed) return;

        if (_openSections.Contains(sectionId))
        {
            _openSections.Remove(sectionId);
        }
        else
        {
            _openSections.Add(sectionId);
        }
        StateHasChanged();
    }
}