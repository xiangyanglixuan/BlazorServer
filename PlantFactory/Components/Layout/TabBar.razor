@* Components/Layout/TabBar.razor *@
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@using PlantFactory.Components.Services
@inject LanguageService Lang
@implements IDisposable

<nav class="tab-nav" aria-label="标签页导航">
    <div class="tab-container">
        @foreach (var tab in _tabs)
        {
            <div class="@GetTabClass(tab)"
                 @onclick="() => SwitchToTab(tab)"
                 title="@tab.Title"
                 role="tab"
                 aria-selected="@tab.IsActive">

                @if (!string.IsNullOrEmpty(tab.Icon))
                {
                    <i class="@tab.Icon" aria-hidden="true"></i>
                }
                <span>@tab.Title</span>

                @if (tab.CanClose)
                {
                    <i class="fas fa-times tab-close"
                       @onclick:stopPropagation="true"
                       @onclick="() => CloseTab(tab)"
                       role="button"
                       aria-label="关闭标签页"></i>
                }
            </div>
        }
    </div>
</nav>

@code {
    private List<TabItem> _tabs = new();
    private const int MAX_TABS = 10;
    private readonly SemaphoreSlim _navigationLock = new(1, 1);
    private string _currentUrl = "";
    private bool _disposed = false; // 添加释放标志
    private CancellationTokenSource _cts = new(); // 添加取消令牌源

    protected override void OnInitialized()
    {
        Lang.OnLanguageChanged += OnLanguageChanged;
        InitializeHomeTab();
        NavigationManager.LocationChanged += OnLocationChanged;
        _currentUrl = NavigationManager.Uri;
    }

    private async void OnLanguageChanged()
    {
        // 更新所有tab标题
        foreach (var tab in _tabs)
        {
            if (string.IsNullOrEmpty(tab.Url) || tab.Url == "/")
                tab.Title = Lang.T("TabHome");
            else
                tab.Title = GetPageTitle(tab.Url);
        }
        await InvokeAsync(StateHasChanged);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // 初始化时检查当前URL
            _ = Task.Run(async () => await SafeHandleLocationChanged(NavigationManager.Uri));
        }
    }

    private void InitializeHomeTab()
    {
        _tabs.Add(new TabItem
        {
            Title = Lang.T("TabHome"),
            Url = "/",
            Icon = "fas fa-home",
            IsActive = true,
            CanClose = false
        });
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // 如果已释放，直接返回
        if (_disposed) return;

        // 避免重复处理相同的URL
        if (_currentUrl.Equals(e.Location, StringComparison.OrdinalIgnoreCase))
            return;

        _currentUrl = e.Location;

        try
        {
            await SafeHandleLocationChanged(e.Location);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"处理路由变化时出错: {ex.Message}");
        }
    }

    private async Task SafeHandleLocationChanged(string location)
    {
        // 如果已释放，直接返回
        if (_disposed) return;

        try
        {
            // 使用取消令牌
            using var cts = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token);
            cts.CancelAfter(5000); // 5秒超时

            if (!await _navigationLock.WaitAsync(0, cts.Token))
                return;

            try
            {
                await HandleLocationChanged(location);
            }
            finally
            {
                if (!_disposed)
                {
                    _navigationLock.Release();
                }
            }
        }
        catch (OperationCanceledException)
        {
            Console.WriteLine("处理路由变化操作已取消");
        }
        catch (ObjectDisposedException)
        {
            Console.WriteLine("对象已释放，忽略操作");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SafeHandleLocationChanged 错误: {ex.Message}");
        }
    }

    private async Task HandleLocationChanged(string location)
    {
        // 如果已释放，直接返回
        if (_disposed) return;

        try
        {
            await AddOrActivateTab(location);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"处理路由变化时出错: {ex.Message}");
        }
    }

    private string GetTabClass(TabItem tab)
    {
        var classes = "tab-item";
        if (tab.IsActive) classes += " active";
        return classes;
    }

    private async Task SwitchToTab(TabItem tab)
    {
        // 如果已释放，直接返回
        if (_disposed) return;

        try
        {
            using var cts = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token);
            cts.CancelAfter(5000);

            if (!await _navigationLock.WaitAsync(0, cts.Token))
                return;

            try
            {
                await HandleSwitchToTab(tab);
            }
            finally
            {
                if (!_disposed)
                {
                    _navigationLock.Release();
                }
            }
        }
        catch (OperationCanceledException)
        {
            Console.WriteLine("切换标签页操作已取消");
        }
        catch (ObjectDisposedException)
        {
            Console.WriteLine("对象已释放，忽略操作");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SwitchToTab 错误: {ex.Message}");
        }
    }

    private async Task HandleSwitchToTab(TabItem tab)
    {
        // 如果已释放，直接返回
        if (_disposed) return;

        if (tab.IsActive)
            return;

        // 更新激活状态
        UpdateActiveTab(tab);

        // 导航到对应URL
        var targetUrl = NavigationManager.ToAbsoluteUri(tab.Url).ToString();
        var currentUrl = NavigationManager.Uri;

        if (!currentUrl.Equals(targetUrl, StringComparison.OrdinalIgnoreCase))
        {
            NavigationManager.NavigateTo(tab.Url);
        }
        else
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void UpdateActiveTab(TabItem activeTab)
    {
        foreach (var t in _tabs)
        {
            t.IsActive = t == activeTab;
        }
    }

    private async Task CloseTab(TabItem tab)
    {
        // 如果已释放，直接返回
        if (_disposed) return;

        if (!tab.CanClose || _tabs.Count <= 1)
            return;

        var wasActive = tab.IsActive;
        var tabIndex = _tabs.IndexOf(tab);

        _tabs.Remove(tab);

        if (wasActive && _tabs.Any())
        {
            // 优先激活前一个标签，如果没有则激活后一个
            var nextTab = tabIndex > 0 ? _tabs[tabIndex - 1] : _tabs[0];
            nextTab.IsActive = true;

            await NavigateToTabIfNeeded(nextTab);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task NavigateToTabIfNeeded(TabItem tab)
    {
        // 如果已释放，直接返回
        if (_disposed) return;

        var currentUrl = NavigationManager.Uri;
        var targetUrl = NavigationManager.ToAbsoluteUri(tab.Url).ToString();

        if (!currentUrl.Equals(targetUrl, StringComparison.OrdinalIgnoreCase))
        {
            NavigationManager.NavigateTo(tab.Url);
        }
    }

    private async Task AddOrActivateTab(string url)
    {
        // 如果已释放，直接返回
        if (_disposed) return;

        try
        {
            var relativePath = NavigationManager.ToBaseRelativePath(url);

            // 如果是登录页，不添加标签
            if (relativePath.Equals("login", StringComparison.OrdinalIgnoreCase))
            {
                return;
            }

            // 如果是首页
            if (string.IsNullOrEmpty(relativePath))
            {
                var homeTab = _tabs.FirstOrDefault(t => t.Url == "/");
                if (homeTab != null)
                {
                    UpdateActiveTab(homeTab);
                }
                return;
            }

            // 检查是否超过最大标签页数
            if (_tabs.Count >= MAX_TABS)
            {
                await JSRuntime.InvokeVoidAsync("alert", string.Format(Lang.T("TabMaxAlert"), MAX_TABS));
                return;
            }

            // 标准化URL
            var normalizedPath = NormalizePath(relativePath);
            var fullPath = "/" + normalizedPath;

            // 查找是否已存在该标签
            var existingTab = _tabs.FirstOrDefault(t =>
                !string.IsNullOrEmpty(t.Url) &&
                NormalizePath(t.Url).Equals(normalizedPath, StringComparison.OrdinalIgnoreCase));

            if (existingTab != null)
            {
                // 如果标签已存在，只需激活它
                UpdateActiveTab(existingTab);
            }
            else
            {
                // 创建新标签
                var newTab = new TabItem
                {
                    Title = GetPageTitle(normalizedPath),
                    Url = fullPath,
                    Icon = GetPageIcon(normalizedPath),
                    IsActive = true,
                    CanClose = true
                };

                // 先将新标签设置为激活
                UpdateActiveTab(newTab);
                // 然后添加新标签
                _tabs.Add(newTab);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"AddOrActivateTab 错误: {ex.Message}");
        }
    }

    private string NormalizePath(string path)
    {
        if (string.IsNullOrEmpty(path)) return "";
        return path.TrimStart('/').ToLowerInvariant();
    }

    private string GetPageTitle(string path)
    {
        var normalizedPath = NormalizePath(path);

        return normalizedPath switch
        {
            "location-monitoring" => Lang.T("TabLocationStatus"),
            "location-analysis" => Lang.T("TabLocationAnalysis"),
            "air-monitoring" => Lang.T("TabAirMonitor"),
            "nutrient-monitoring" => Lang.T("TabNutrientMonitor"),
            "plant-category" => Lang.T("TabPlantCategory"),
            "growth-formula" => Lang.T("TabGrowthFormula"),
            "inbound" => Lang.T("TabInbound"),
            "outbound" => Lang.T("TabOutbound"),
            "alarm-management" => Lang.T("TabAlarm"),
            "device-monitoring" => Lang.T("TabDeviceStatus"),
            "data-statistics" => Lang.T("TabDataStats"),
            "" => Lang.T("TabHome"),
            _ => FormatTitle(normalizedPath)
        };
    }

    private string FormatTitle(string path)
    {
        // 将路径格式化为标题
        return string.Join(" ", path.Split('-')
            .Select(word => char.ToUpper(word[0]) + word.Substring(1)));
    }

    private string GetPageIcon(string path)
    {
        var normalizedPath = NormalizePath(path);

        return normalizedPath switch
        {
            "location-monitoring" => "fas fa-circle-notch",
            "location-analysis" => "fas fa-chart-bar",
            "air-monitoring" => "fas fa-wind",
            "nutrient-monitoring" => "fas fa-tint",
            "plant-category" => "fas fa-leaf",
            "growth-formula" => "fas fa-prescription-bottle",
            "inbound" => "fas fa-sign-in-alt",
            "outbound" => "fas fa-sign-out-alt",
            "alarm-management" => "fas fa-exclamation-triangle",
            "device-monitoring" => "fas fa-desktop",
            "data-statistics" => "fas fa-chart-line",
            "" => "fas fa-home",
            _ => "fas fa-file"
        };
    }

    public void Dispose()
    {
        if (_disposed) return;

        _disposed = true;

        _cts.Cancel();
        _cts.Dispose();

        NavigationManager.LocationChanged -= OnLocationChanged;
        Lang.OnLanguageChanged -= OnLanguageChanged;

        try
        {
            _navigationLock?.Dispose();
        }
        catch
        {
            // 忽略释放时的错误
        }
    }

    private class TabItem
    {
        public string Title { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
        public string Icon { get; set; } = string.Empty;
        public bool IsActive { get; set; }
        public bool CanClose { get; set; } = true;
    }
}