    private async Task<bool> CheckLoginStatus()
    {
        try
        {
            var localLogin = await JS.InvokeAsync<string>("localStorage.getItem", "isLoggedIn");
            if (localLogin == "true")
                return true;

            var sessionLogin = await JS.InvokeAsync<string>("sessionStorage.getItem", "isLoggedIn");
            return sessionLogin == "true";
        }
        catch
        {
            return false;
        }
    }

