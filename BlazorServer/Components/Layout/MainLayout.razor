    private async Task<string> GetLoginTime()
    {
        try
        {
            var time = await JS.InvokeAsync<string>("localStorage.getItem", "loginTime");
            if (string.IsNullOrEmpty(time))
            {
                time = await JS.InvokeAsync<string>("sessionStorage.getItem", "loginTime");
            }
            
            if (string.IsNullOrEmpty(time))
            {
                return DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
            }
            
            return time;
