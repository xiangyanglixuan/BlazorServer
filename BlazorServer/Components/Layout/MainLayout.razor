                    "manager" => "manager@blazorserver.com",
                    "operator" => "operator@blazorserver.com",
                    _ => "user@blazorserver.com"
                };
            }
            
            return email ?? "user@blazorserver.com";
        }
        catch
        {
            return "user@blazorserver.com";
        }
    }

