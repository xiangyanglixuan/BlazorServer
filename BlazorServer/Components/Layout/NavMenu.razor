@* Components/Layout/NavMenu.razor *@
@using Microsoft.AspNetCore.Components.Routing
@using BlazorServer.Services
@inject LanguageService Lang
@implements IDisposable

<div class="nav-container">
    @* 带有二级菜单的项 *@
    @* <NavMenuItem Title="@Lang.T("MenuLocationMonitor")"
                 Icon="fas fa-th-large"
                 IsOpen="@IsSectionOpen("location")"
                 OnToggle="@(() => ToggleSection("location"))"
                 Collapsed="@SidebarCollapsed">
        <NavLink href="/location-monitoring" class="sub-nav">
            <i class="fas fa-circle-notch"></i>
            <span>@Lang.T("MenuLocationStatus")</span>
        </NavLink>
        <NavLink href="/location-analysis" class="sub-nav">
            <i class="fas fa-chart-bar"></i>
            <span>@Lang.T("MenuLocationAnalysis")</span>
        </NavLink>
    </NavMenuItem> *@


    @* 普通菜单项 *@
    <NavLink href="/Scada" class="nav-link" data-title="@Lang.T("Scada")">
        <i class="fas fa-circle-notch"></i>
        <span>@Lang.T("Scada")</span>
    </NavLink>

    <NavLink href="/HKScada" class="nav-link" data-title="@Lang.T("HKScada")">
        <i class="fas fa-hard-hat"></i>
        <span>@Lang.T("HKScada")</span>
    </NavLink>

    <NavLink href="/DDKScada" class="nav-link" data-title="@Lang.T("DDKScada")">
        <i class="fas fa-boxes"></i>
        <span>@Lang.T("DDKScada")</span>
    </NavLink>

    <NavLink href="/KKScada" class="nav-link" data-title="@Lang.T("KKScada")">
        <i class="fas fa-air-freshener"></i>
        <span>@Lang.T("KKScada")</span>
    </NavLink>

    <NavLink href="/Alarm" class="nav-link" data-title="@Lang.T("TabAlarm")">
        <i class="fas fa-chart-bar"></i>
        <span>@Lang.T("TabAlarm")</span>
    </NavLink>

    @* 普通菜单项 *@
    <NavLink href="/Interfollow" class="nav-link" data-title="@Lang.T("TabInterfollow")">
        <i class="fas fa-wind"></i>
        <span>@Lang.T("TabInterfollow")</span>
    </NavLink>
</div>

@code {
    [CascadingParameter]
    private bool SidebarCollapsed { get; set; }

    private HashSet<string> _openSections = new HashSet<string>();

    protected override void OnInitialized()
    {
        Lang.OnLanguageChanged += StateHasChanged;
    }

    private bool IsSectionOpen(string sectionId)
    {
        return _openSections.Contains(sectionId);
    }

    private void ToggleSection(string sectionId)
    {
        if (SidebarCollapsed) return;

        if (_openSections.Contains(sectionId))
        {
            _openSections.Remove(sectionId);
        }
        else
        {
            _openSections.Add(sectionId);
        }
        StateHasChanged();
    }

    public void Dispose()
    {
        Lang.OnLanguageChanged -= StateHasChanged;
    }
}